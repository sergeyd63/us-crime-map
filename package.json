{
  "name": "official-crime-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server:dev\" \"npm:client:dev\"",
    "client:dev": "vite --host 0.0.0.0",
    "server:dev": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "npm run build && node dist-server/server/index.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.17",
    "concurrently": "^9.1.2",
    "d3-array": "^3.2.4",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "tsx": "^4.19.2",
    "us-atlas": "^3.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-scale": "^4.0.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/topojson-client": "^3.1.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
