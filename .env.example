# Required for full refreshes from the official FBI Crime Data API.
# Sign up at https://api.data.gov/signup/
FBI_API_KEY=

# Optional. The default is the current public FBI CDE gateway namespace.
FBI_API_BASE=https://api.usa.gov/crime/fbi/cde

# Optional. Current FBI CDE annual CIUS publication year used by this app.
CRIME_DATA_YEAR=2024

# Optional. Official Census county population CSV used for county percentage coloring.
# Defaults to the Census Population Estimates file for CRIME_DATA_YEAR.
COUNTY_POPULATION_URL=

# Optional cache duration for API responses.
CACHE_TTL_MINUTES=1440

# Optional server port.
PORT=5174
